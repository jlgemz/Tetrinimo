{
  "name": "magic-patterns-vite-template",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:win": "powershell -ExecutionPolicy Bypass -File scripts/dev-all.ps1",
    "dev:all": "powershell -ExecutionPolicy Bypass -File scripts/dev-all.ps1",
    "dev:api": "powershell -ExecutionPolicy Bypass -File scripts/dev-api.ps1",
    "setup:backend": "powershell -ExecutionPolicy Bypass -File scripts/setup-backend.ps1",
    "test:api": "powershell -ExecutionPolicy Bypass -File scripts/test-api.ps1",
    "dev:free": "powershell -ExecutionPolicy Bypass -File scripts/free-port.ps1",
    "dev:free:api": "powershell -ExecutionPolicy Bypass -File scripts/free-port.ps1 -Port 8000",
    "build": "vite build",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@emotion/react": "^11.13.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.18",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^5.54.0",
    "@typescript-eslint/parser": "^5.54.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.50.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.1",
    "typescript": "^5.5.4",
    "vite": "^5.2.0",
    "tailwindcss": "3.4.17",
    "autoprefixer": "latest",
    "postcss": "latest"
  }
}